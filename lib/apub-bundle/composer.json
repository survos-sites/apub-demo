{
    "name": "survos/activity-pub-bundle",
    "description": "ActivityPub federation (actors, WebFinger, inbox/outbox, HTTP Signatures) with no knowledge of what's being federated",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "activitypub",
        "fediverse",
        "federation",
        "webfinger"
    ],
    "autoload": {
        "psr-4": {
            "Survos\\ActivityPubBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Survos\\ActivityPubBundle\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.5",
        "doctrine/orm": "^3.3",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/dbal": "^3.9||^4.2",
        "symfony/config": "^8.1",
        "symfony/console": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/http-foundation": "^8.1",
        "symfony/http-kernel": "^8.1",
        "symfony/http-client": "^8.1",
        "symfony/messenger": "^8.1",
        "symfony/routing": "^8.1",
        "symfony/uid": "^8.1",
        "survos/kit-bundle": "^2.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse"
    },
    "extra": {
        "symfony": {
            "require": "^8.0"
        }
    }
}
