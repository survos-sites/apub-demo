{
    "controllers": {
        "@survos/tabler-bundle": {
            "accordion": {
                "enabled": true,
                "fetch": "lazy"
            },
            "search": {
                "enabled": true,
                "fetch": "lazy"
            }
        },
        "@symfony/ux-turbo": {
            "turbo-core": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": {
                    "@symfony/ux-turbo/dist/mercure_stream_source_element.js": true
                }
            },
            "mercure-turbo-stream": {
                "enabled": false,
                "fetch": "eager"
            }
        }
    },
    "entrypoints": []
}
