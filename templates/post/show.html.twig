{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
    <div class="page-body">
        <div class="container-xl">
            <a href="{{ path('app_homepage') }}" class="text-muted">&larr; All posts</a>
            <h2 class="mt-2">{{ post.title }}</h2>
            <div class="text-muted mb-3">
                by {{ post.author.email }} — {{ post.published|date('Y-m-d H:i') }}
            </div>
            <div class="card">
                <div class="card-body">
                    {{ post.body|nl2br }}
                </div>
            </div>

            {% if authorHandle %}
                <div class="card mt-3 bg-azure-lt">
                    <div class="card-body">
                        <strong>
                            Federated as
                            <a href="{{ mastodonFollowUrl }}" target="_blank" rel="noopener">
                                <code>@{{ authorHandle }}</code>
                            </a>
                        </strong>
                        <div class="text-muted">
                            Click to follow from mastodon.social, or search this handle from any Mastodon
                            (or other ActivityPub) account, to receive future posts as ActivityStreams activities.
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
